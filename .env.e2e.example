# E2E testing environment overrides.
# Copy to .env.e2e and adjust values for your machine.
#
# These values are layered ON TOP of .env when running `pnpm test:e2e`.
# They configure both the Docker e2e container and the Playwright runner
# to use local Supabase and localhost URLs, keeping production data safe.
#
# To add a new Docker-based environment (e.g. staging), copy this file
# to .env.staging, tweak the values, and run:
#   pnpm test:e2e -- --env staging

# ─── Container identity ──────────────────────────────────────────
SITE_PROD_CONTAINER_NAME=candyshop-e2e
SITE_PROD_IMAGE_NAME=candyshop-e2e
SITE_PROD_PORT=8089

# ─── Public origin (what the browser sees) ────────────────────────
SITE_PUBLIC_ORIGIN=http://localhost:8089

# ─── App URLs (baked into Next.js at build time) ──────────────────
NEXT_PUBLIC_LANDING_URL=http://localhost:8089
NEXT_PUBLIC_STORE_URL=http://localhost:8089/store
NEXT_PUBLIC_PAYMENTS_URL=http://localhost:8089/payments
NEXT_PUBLIC_ADMIN_URL=http://localhost:8089/admin
NEXT_PUBLIC_PLAYGROUND_URL=http://localhost:8089/playground
NEXT_PUBLIC_STUDIO_URL=http://localhost:8089/studio
NEXT_PUBLIC_AUTH_URL=http://localhost:8089/auth
NEXT_PUBLIC_AUTH_HOST_URL=http://localhost:8089/auth

# ─── Supabase (local instance) ────────────────────────────────────
# Client-side: browser hits localhost directly
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Server-side: container reaches host Supabase via Docker networking
SUPABASE_URL_INTERNAL=http://host.docker.internal:54321

# ─── Auth provider ────────────────────────────────────────────────
AUTH_PROVIDER_MODE=supabase

# ─── Build flags ──────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_TEST_IDS=true
NEXT_PUBLIC_BUILD_HASH=e2e
