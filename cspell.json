{
  "version": "0.2",
  "language": "en",
  "allowCompoundWords": true,
  "ignorePaths": [
    "node_modules/**",
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/build/**",
    "**/out/**",
    "**/coverage/**",
    "pnpm-lock.yaml",
    "package-lock.json",
    "yarn.lock",
    "**/i18n/messages/*.json",
    "**/api/generated/**",
    "**/types/generated/**",
    "packages/api/src/generated/**"
  ],
  "words": [
    "candyshop",
    "nextintl",
    "next-intl",
    "shadcn",
    "tanstack",
    "recharts",
    "orval",
    "msw",
    "lucide",
    "tailwindcss",
    "pnpm",
    "vite",
    "vitest",
    "clsx",
    "tsx",
    "tsconfig",
    "jsdom",
    "radix",
    "monorepo",
    "syncpack",
    "sherif",
    "secretlint",
    "concurrently",
    "hrefs",
    "jscpd",
    "madge",
    "storefront",
    "cupons",
    "promos"
  ]
}
