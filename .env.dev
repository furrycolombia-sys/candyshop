# =============================================================================
# Dev environment — local Supabase at 127.0.0.1:54321
# =============================================================================
# Used by: pnpm dev, pnpm dev:up
# Loaded when: TARGET_ENV=dev (default)
#
# This file is self-contained. All non-secret config for local development
# lives here. Secret values use $secret:KEY_NAME references resolved from
# the .secrets file (run `pnpm sync-secrets` to populate it).
# =============================================================================

# ─── Supabase (local instance from `supabase start`) ─────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=$secret:DEV_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=$secret:DEV_SUPABASE_SERVICE_ROLE_KEY

# ─── Auth provider ────────────────────────────────────────────────
AUTH_PROVIDER_MODE=supabase

# ─── OAuth providers (local Supabase) ─────────────────────────────
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=$secret:SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=$secret:SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET
SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_ID=$secret:SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_ID
SUPABASE_AUTH_EXTERNAL_DISCORD_SECRET=$secret:SUPABASE_AUTH_EXTERNAL_DISCORD_SECRET

# ─── Public host naming (for tunnel + OAuth redirects) ────────────
SITE_PUBLIC_ORIGIN=https://store.ffxivbe.org
PUBLIC_BASE_DOMAIN=ffxivbe.org
PUBLIC_ROOT_HOST=ffxivbe.org
PUBLIC_WWW_HOST=www.ffxivbe.org
PUBLIC_LANDING_HOST=landing.ffxivbe.org
PUBLIC_AUTH_HOST=auth.ffxivbe.org
PUBLIC_STORE_HOST=store.ffxivbe.org
PUBLIC_ADMIN_HOST=admin.ffxivbe.org
PUBLIC_PLAYGROUND_HOST=playground.ffxivbe.org
PUBLIC_PAYMENTS_HOST=payments.ffxivbe.org
PUBLIC_STUDIO_HOST=studio.ffxivbe.org
PUBLIC_SUPABASE_HOST=supabase.ffxivbe.org
PUBLIC_SUPABASE_STUDIO_HOST=supabase-studio.ffxivbe.org
PUBLIC_MAILPIT_HOST=mailpit.ffxivbe.org

# ─── Supabase (tunneled public endpoint for OAuth) ────────────────
# When using Cloudflare tunnel, OAuth callbacks go through the public URL.
SUPABASE_AUTH_EXTERNAL_REDIRECT_URI=https://supabase.ffxivbe.org/auth/v1/callback
SUPABASE_AUTH_SITE_URL=https://store.ffxivbe.org/auth/callback
SUPABASE_AUTH_REDIRECT_URL_AUTH=https://store.ffxivbe.org/auth/callback
SUPABASE_AUTH_REDIRECT_URL_STORE=https://store.ffxivbe.org/store/auth/callback
SUPABASE_AUTH_REDIRECT_URL_ADMIN=https://store.ffxivbe.org/admin/auth/callback
SUPABASE_AUTH_REDIRECT_URL_PAYMENTS=https://store.ffxivbe.org/payments/auth/callback
SUPABASE_AUTH_REDIRECT_URL_PLAYGROUND=https://store.ffxivbe.org/playground/auth/callback
SUPABASE_AUTH_REDIRECT_URL_LANDING=https://store.ffxivbe.org/auth/callback
SUPABASE_AUTH_REDIRECT_URL_STUDIO=https://store.ffxivbe.org/studio/auth/callback

# ─── Build flags ──────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_TEST_IDS=true
