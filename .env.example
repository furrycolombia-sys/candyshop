=============================================================================
# Monorepo Environment Defaults (committed to git)
# =============================================================================
# This single file provides defaults for ALL apps and root scripts.
# It works out-of-the-box — no setup needed to start developing.
#
# To override any value, create .env (gitignored) at the repo root.
# Your .env only needs the vars you want to change.
#
# Precedence (highest wins):
#   process.env (CLI)  >  .env (local overrides)  >  .env.example (defaults)
# =============================================================================

# -----------------------------------------------------------------------------
# Shared: API Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_PREFIX=/api
NEXT_PUBLIC_ENABLE_MOCKS=true

# -----------------------------------------------------------------------------
# Shared: Project Identity
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PROJECT_ID=candystore-dev-001
NEXT_PUBLIC_TENANT=candystore
NEXT_PUBLIC_BUILD_HASH=local

# -----------------------------------------------------------------------------
# Shared: Cross-App Navigation
# -----------------------------------------------------------------------------
# Defaults use absolute localhost URLs for local dev (pnpm dev).
# Docker/production builds override these via build args.
NEXT_PUBLIC_STORE_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_HOST_URL=http://localhost:3000
NEXT_PUBLIC_PLAYGROUND_URL=http://localhost:3003

# -----------------------------------------------------------------------------
# Shared: Localization
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,es

# -----------------------------------------------------------------------------
# Shared: Development Tools
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_REACT_QUERY_DEVTOOLS=true

# -----------------------------------------------------------------------------
# App: Store — main storefront
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Candy Store"
NEXT_PUBLIC_SHOW_MOCKED_FEATURES=false

# Payment provider (stripe, mock)
NEXT_PUBLIC_PAYMENT_PROVIDER=mock

# Currency and pricing
NEXT_PUBLIC_DEFAULT_CURRENCY=USD
NEXT_PUBLIC_SUPPORTED_CURRENCIES=USD,COP,EUR

# -----------------------------------------------------------------------------
# App: Admin — back-office management
# -----------------------------------------------------------------------------
# Override NEXT_PUBLIC_APP_NAME="Candy Store Admin" in .env if needed

# -----------------------------------------------------------------------------
# App: Auth — authentication provider
# -----------------------------------------------------------------------------
# Switch auth provider:
# - mock: local deterministic mock tokens (default for dev)
# - backend: call backend auth endpoints
# - keycloak: OIDC with Keycloak (Authorization Code + PKCE)
AUTH_PROVIDER_MODE=mock

# Used only when AUTH_PROVIDER_MODE=backend
AUTH_BACKEND_BASE_URL=http://localhost:8080
AUTH_BACKEND_LOGIN_PATH=/auth/login
AUTH_BACKEND_REFRESH_PATH=/auth/refresh

# Keycloak (when AUTH_PROVIDER_MODE=keycloak). Override in .env with real values.
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=candystore
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=candystore-ui

# -----------------------------------------------------------------------------
# Docker / Standalone: Base Path Prefix
# -----------------------------------------------------------------------------
BASE_PATH_PREFIX=

# Mock login form defaults (for local/demo convenience)
AUTH_MOCK_DEFAULT_EMAIL=mock.user@example.invalid
AUTH_MOCK_DEFAULT_PASSWORD=not-a-real-password

# -----------------------------------------------------------------------------
# Root Scripts: Code Generation (Orval & GraphQL)
# -----------------------------------------------------------------------------
# ORVAL_OPENAPI_URL=http://localhost:8000/openapi.json
# GRAPHQL_ENDPOINT_URL=http://localhost:8000/graphql
