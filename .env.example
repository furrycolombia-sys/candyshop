=============================================================================
# Monorepo Environment Defaults (committed to git)
# =============================================================================
# This file provides base defaults for ALL apps and root scripts.
# Environment-specific config lives in .env.{TARGET_ENV} files:
#   .env.dev      — local development (default)
#   .env.staging  — Docker staging with Cloudflare tunnel
#   .env.e2e      — isolated E2E testing
#   .env.prod     — production (Supabase Cloud)
#
# Precedence (highest wins):
#   process.env (CLI/CI) > secret resolution > .env.{TARGET_ENV} > .env.example
#
# Secret references:
#   Values like `$secret:KEY_NAME` are resolved from the .secrets file.
#   Run `pnpm sync-secrets` to fetch secrets from GitHub.
#   In CI, secrets are injected directly via process.env.
#   Escape with `$$secret:` to produce the literal string `$secret:`.
# =============================================================================

# -----------------------------------------------------------------------------
# Environment Selection
# -----------------------------------------------------------------------------
# Set TARGET_ENV to choose which .env.{name} file to load.
# Defaults to "dev" when not set.
# TARGET_ENV=dev

# -----------------------------------------------------------------------------
# Shared: API Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_API_PREFIX=/api
NEXT_PUBLIC_ENABLE_MOCKS=false

# -----------------------------------------------------------------------------
# Shared: Project Identity
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PROJECT_ID=candyshop-dev-001
NEXT_PUBLIC_TENANT=candyshop
NEXT_PUBLIC_BUILD_HASH=local

# -----------------------------------------------------------------------------
# Shared: Cross-App Navigation
# -----------------------------------------------------------------------------
# Defaults use absolute localhost URLs for local dev (pnpm dev).
# Docker/production builds override these via build args.
NEXT_PUBLIC_STORE_URL=http://localhost:5001
NEXT_PUBLIC_ADMIN_URL=http://localhost:5002
NEXT_PUBLIC_PLAYGROUND_URL=http://localhost:5003
NEXT_PUBLIC_LANDING_URL=http://localhost:5004
NEXT_PUBLIC_PAYMENTS_URL=http://localhost:5005
NEXT_PUBLIC_STUDIO_URL=http://localhost:5006
NEXT_PUBLIC_AUTH_URL=http://localhost:5000
NEXT_PUBLIC_AUTH_HOST_URL=http://localhost:5000

# Optional: Cloudflare tunnel for public access
# CLOUDFLARE_TUNNEL_NAME=
# CLOUDFLARE_TUNNEL_TOKEN=
# CLOUDFLARED_ARGS=tunnel run your-tunnel-name

# Public host naming for tunnel + OAuth redirects.
# Override these in `.env` per environment instead of editing code.
PUBLIC_BASE_DOMAIN=ffxivbe.org
PUBLIC_ROOT_HOST=ffxivbe.org
PUBLIC_WWW_HOST=www.ffxivbe.org
PUBLIC_LANDING_HOST=landing.ffxivbe.org
PUBLIC_AUTH_HOST=auth.ffxivbe.org
PUBLIC_STORE_HOST=store.ffxivbe.org
PUBLIC_ADMIN_HOST=admin.ffxivbe.org
PUBLIC_PLAYGROUND_HOST=playground.ffxivbe.org
PUBLIC_PAYMENTS_HOST=payments.ffxivbe.org
PUBLIC_STUDIO_HOST=studio.ffxivbe.org
PUBLIC_SUPABASE_HOST=supabase.ffxivbe.org
PUBLIC_SUPABASE_STUDIO_HOST=supabase-studio.ffxivbe.org
PUBLIC_MAILPIT_HOST=mailpit.ffxivbe.org

# Local services behind the named Cloudflare tunnel.
CLOUDFLARE_SERVICE_ROOT=http://127.0.0.1:9000
CLOUDFLARE_SERVICE_WWW=http://127.0.0.1:9000
CLOUDFLARE_SERVICE_LANDING=http://127.0.0.1:5004
CLOUDFLARE_SERVICE_AUTH=http://127.0.0.1:5000
CLOUDFLARE_SERVICE_STORE=http://127.0.0.1:8088
CLOUDFLARE_SERVICE_ADMIN=http://127.0.0.1:5002
CLOUDFLARE_SERVICE_PLAYGROUND=http://127.0.0.1:5003
CLOUDFLARE_SERVICE_PAYMENTS=http://127.0.0.1:5005
CLOUDFLARE_SERVICE_STUDIO=http://127.0.0.1:5006
CLOUDFLARE_SERVICE_SUPABASE=http://127.0.0.1:54321
CLOUDFLARE_SERVICE_SUPABASE_STUDIO=http://127.0.0.1:54323
CLOUDFLARE_SERVICE_MAILPIT=http://127.0.0.1:54324

# Optional: Docker production stack + public origin
# SITE_PROD_PORT=8088
# SITE_PROD_CONTAINER_NAME=candyshop-prod
# SITE_PROD_IMAGE_NAME=candyshop-local-prod
# SITE_PUBLIC_ORIGIN=https://shop.example.com

# -----------------------------------------------------------------------------
# Shared: Localization
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,es

# -----------------------------------------------------------------------------
# Shared: Development Tools
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_REACT_QUERY_DEVTOOLS=true

# -----------------------------------------------------------------------------
# App: Store — main storefront
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Candy Shop"
NEXT_PUBLIC_SHOW_MOCKED_FEATURES=false

# Payment provider (stripe, mock)
NEXT_PUBLIC_PAYMENT_PROVIDER=mock

# Currency and pricing
NEXT_PUBLIC_DEFAULT_CURRENCY=USD
NEXT_PUBLIC_SUPPORTED_CURRENCIES=USD,COP,EUR

# -----------------------------------------------------------------------------
# App: Admin — back-office management
# -----------------------------------------------------------------------------
# Override NEXT_PUBLIC_APP_NAME="Candy Shop Admin" in .env if needed

# -----------------------------------------------------------------------------
# App: Auth — authentication provider
# -----------------------------------------------------------------------------
# Switch auth provider:
# - mock: local deterministic mock tokens (default for dev)
# - supabase: Supabase Auth with social login (Google, Facebook)
# - backend: call backend auth endpoints
# - keycloak: OIDC with Keycloak (Authorization Code + PKCE)
AUTH_PROVIDER_MODE=supabase

# Used only when AUTH_PROVIDER_MODE=backend
AUTH_BACKEND_BASE_URL=http://localhost:8080
AUTH_BACKEND_LOGIN_PATH=/auth/login
AUTH_BACKEND_REFRESH_PATH=/auth/refresh

# Keycloak (when AUTH_PROVIDER_MODE=keycloak). Override in .env with real values.
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=candyshop
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=candyshop-ui

# -----------------------------------------------------------------------------
# Docker / Standalone: Base Path Prefix
# -----------------------------------------------------------------------------
BASE_PATH_PREFIX=

# Mock login form defaults (for local/demo convenience)
AUTH_MOCK_DEFAULT_EMAIL=mock.user@example.invalid
AUTH_MOCK_DEFAULT_PASSWORD=not-a-real-password

# -----------------------------------------------------------------------------
# Shared: Supabase
# -----------------------------------------------------------------------------
# Local dev defaults (from `supabase start`). Secret values are resolved
# from .secrets via $secret: references in each .env.{TARGET_ENV} file.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# -----------------------------------------------------------------------------
# Shared: OAuth Providers (obtain from each provider's developer portal)
# -----------------------------------------------------------------------------
# Public auth redirect defaults for Supabase local auth.
SUPABASE_AUTH_SITE_URL=https://store.ffxivbe.org/auth/callback
SUPABASE_AUTH_REDIRECT_URL_AUTH=https://auth.ffxivbe.org/auth/callback
SUPABASE_AUTH_REDIRECT_URL_STORE=https://store.ffxivbe.org/auth/callback
SUPABASE_AUTH_REDIRECT_URL_ADMIN=https://admin.ffxivbe.org/auth/callback
SUPABASE_AUTH_REDIRECT_URL_PAYMENTS=https://payments.ffxivbe.org/auth/callback
SUPABASE_AUTH_REDIRECT_URL_PLAYGROUND=https://playground.ffxivbe.org/auth/callback
SUPABASE_AUTH_REDIRECT_URL_LANDING=https://landing.ffxivbe.org/auth/callback
SUPABASE_AUTH_REDIRECT_URL_STUDIO=https://studio.ffxivbe.org/auth/callback
SUPABASE_AUTH_EXTERNAL_REDIRECT_URI=https://supabase.ffxivbe.org/auth/v1/callback

# Google: https://console.cloud.google.com/apis/credentials
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# Discord: https://discord.com/developers/applications
SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_DISCORD_SECRET=
# OAuth callback URL for all providers (local): http://127.0.0.1:54321/auth/v1/callback

# -----------------------------------------------------------------------------
# Root Scripts: Code Generation (Orval & GraphQL)
# -----------------------------------------------------------------------------
# ORVAL_OPENAPI_URL=http://localhost:8000/openapi.json
# GRAPHQL_ENDPOINT_URL=http://localhost:8000/graphql
