# =============================================================================
# Test environment — same as dev, used for isolated test runs
# =============================================================================
TARGET_ENV=test

# ─── Topology ─────────────────────────────────────────────────────
APPS_MODE=local
SUPABASE_MODE=local
TUNNEL_MODE=none

# ─── Container identity (unused in test, kept for parity) ─────────
SITE_PROD_CONTAINER_NAME=candyshop-test
SITE_PROD_IMAGE_NAME=candyshop-test

# ─── App origins ──────────────────────────────────────────────────
APP_PUBLIC_ORIGIN=http://localhost:8088
APP_INTERNAL_ORIGIN=http://localhost:8088

# ─── Supabase ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:64321  # matches SUPABASE_PORT
NEXT_PUBLIC_SUPABASE_ANON_KEY=$secret:DEV_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=$secret:DEV_SUPABASE_SERVICE_ROLE_KEY

# Supabase Docker base port — all other ports are derived from this
SUPABASE_PORT=64321
STAGING_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
STAGING_POSTGRES_PASSWORD=postgres

# ─── Auth ─────────────────────────────────────────────────────────
AUTH_PROVIDER_MODE=supabase

# ─── Cross-app navigation ─────────────────────────────────────────
NEXT_PUBLIC_LANDING_URL=http://localhost:7000
NEXT_PUBLIC_AUTH_URL=http://localhost:7001
NEXT_PUBLIC_AUTH_HOST_URL=http://localhost:7001
NEXT_PUBLIC_STORE_URL=http://localhost:7002
NEXT_PUBLIC_ADMIN_URL=http://localhost:7003
NEXT_PUBLIC_PLAYGROUND_URL=http://localhost:7004
NEXT_PUBLIC_PAYMENTS_URL=http://localhost:7005
NEXT_PUBLIC_STUDIO_URL=http://localhost:7006

# ─── OAuth providers ──────────────────────────────────────────────
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=$secret:SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=$secret:SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET
SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_ID=$secret:SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_ID
SUPABASE_AUTH_EXTERNAL_DISCORD_SECRET=$secret:SUPABASE_AUTH_EXTERNAL_DISCORD_SECRET
SUPABASE_AUTH_EXTERNAL_REDIRECT_URI=http://127.0.0.1:64321/auth/v1/callback
SUPABASE_AUTH_SITE_URL=http://localhost:7001/auth/callback

# ─── Build flags ──────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_TEST_IDS=true
NEXT_PUBLIC_BUILD_HASH=test
ENV_DEBUG=true

# ─── Cloudflare (unused in test, kept for parity) ─────────────────
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARED_CONFIG_DIR=~/.cloudflared

# ─── E2E test account ─────────────────────────────────────────────
GOOGLE_TEST_EMAIL=$secret:GOOGLE_TEST_EMAIL
GOOGLE_TEST_PASSWORD=$secret:GOOGLE_TEST_PASSWORD
