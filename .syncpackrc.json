{
  "$schema": "https://unpkg.com/syncpack@14/dist/index.json",
  "versionGroups": [
    {
      "label": "Internal workspace packages use workspace:* protocol",
      "packages": ["**"],
      "dependencies": ["api", "shared", "ui", "auth"],
      "dependencyTypes": ["prod", "dev"],
      "pinVersion": "workspace:*"
    },
    {
      "label": "React peer dependencies in packages can differ from apps",
      "dependencies": ["react", "react-dom"],
      "dependencyTypes": ["peer"],
      "isIgnored": true
    }
  ]
}
