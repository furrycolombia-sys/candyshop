{
  "name": "candystore",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n store,landing,payments,admin,auth,playground -c blue,cyan,green,magenta,yellow,red \"pnpm dev:store\" \"pnpm dev:landing\" \"pnpm dev:payments\" \"pnpm dev:admin\" \"pnpm dev:auth\" \"pnpm dev:playground\"",
    "dev:store": "pnpm --filter store dev",
    "dev:landing": "pnpm --filter landing dev",
    "dev:payments": "pnpm --filter payments dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:auth": "pnpm --filter auth-app dev",
    "dev:playground": "pnpm --filter playground dev",
    "build": "pnpm -r build",
    "build:store": "pnpm --filter store build",
    "build:landing": "pnpm --filter landing build",
    "build:payments": "pnpm --filter payments build",
    "build:admin": "pnpm --filter admin build",
    "build:auth": "pnpm --filter auth-app build",
    "build:playground": "pnpm --filter playground build",
    "lint": "eslint apps/store/src apps/landing/src apps/payments/src apps/admin/src apps/auth/src apps/playground/src packages/ui/src packages/shared/src packages/api/src packages/app-components/src packages/auth/src",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:store": "pnpm --filter store test",
    "test:landing": "pnpm --filter landing test",
    "test:payments": "pnpm --filter payments test",
    "test:admin": "pnpm --filter admin test",
    "test:auth": "pnpm --filter auth-app test",
    "test:playground": "pnpm --filter playground test",
    "test:watch": "pnpm --filter store test:watch",
    "test:coverage": "pnpm -r test:coverage",
    "test:coverage:store": "pnpm --filter store test:coverage",
    "test:coverage:landing": "pnpm --filter landing test:coverage",
    "test:coverage:payments": "pnpm --filter payments test:coverage",
    "test:coverage:admin": "pnpm --filter admin test:coverage",
    "test:coverage:auth": "pnpm --filter auth-app test:coverage",
    "test:coverage:playground": "pnpm --filter playground test:coverage",
    "test:shared": "pnpm --filter shared test",
    "test:ui": "pnpm --filter ui test",
    "test:e2e": "pnpm -r --workspace-concurrency=1 test:e2e",
    "test:e2e:store": "pnpm --filter store test:e2e",
    "test:e2e:landing": "pnpm --filter landing test:e2e",
    "test:e2e:payments": "pnpm --filter payments test:e2e",
    "test:e2e:admin": "pnpm --filter admin test:e2e",
    "test:e2e:auth": "pnpm --filter auth-app test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "fix:staged": "lint-staged --concurrent false",
    "fix:all": "pnpm format && eslint --fix apps/store/src apps/landing/src apps/payments/src apps/admin/src apps/auth/src apps/playground/src packages/ui/src packages/shared/src packages/api/src packages/app-components/src packages/auth/src",
    "stylelint": "stylelint \"apps/*/src/**/*.css\" \"packages/*/src/**/*.css\"",
    "css-sync": "node scripts/check-css-sync.mjs",
    "cspell": "cspell \"apps/*/src/**/*.{ts,tsx,js,jsx,md}\" \"packages/*/src/**/*.{ts,tsx}\"",
    "knip": "knip",
    "jscpd": "jscpd apps/store/src apps/landing/src apps/payments/src apps/admin/src apps/auth/src apps/playground/src packages/ui/src packages/shared/src packages/api/src packages/app-components/src packages/auth/src",
    "ls-lint": "ls-lint",
    "madge": "madge --circular --extensions ts,tsx,js,jsx apps/store/src apps/landing/src apps/payments/src apps/admin/src apps/auth/src apps/playground/src packages/ui/src packages/shared/src packages/api/src packages/app-components/src packages/auth/src",
    "check:registry": "bash scripts/check-app-registry.sh",
    "sherif": "sherif",
    "sherif:fix": "sherif --fix",
    "syncpack:list": "syncpack list-mismatches --filter \"^(?!@monorepo/app-components$|auth$).*\"",
    "syncpack:fix": "syncpack fix-mismatches",
    "secretlint": "secretlint \"**/*\"",
    "semgrep": "semgrep scan --config p/ci --config p/security-audit --config p/owasp-top-ten",
    "precommit": "pnpm lint-staged && pnpm lint && pnpm stylelint && pnpm css-sync && pnpm cspell && pnpm knip && pnpm jscpd && pnpm ls-lint && pnpm madge && pnpm sherif && pnpm syncpack:list",
    "prepush": "pnpm typecheck && pnpm test:coverage && pnpm build && pnpm test:e2e",
    "codegen": "node scripts/refresh-openapi-mocks.mjs",
    "codegen:fetch": "node scripts/refresh-openapi-mocks.mjs --fetch-only",
    "codegen:process": "node scripts/refresh-openapi-mocks.mjs --process-only",
    "codegen:graphql": "graphql-codegen --config graphql-codegen.ts",
    "codegen:graphql:watch": "graphql-codegen --config graphql-codegen.ts --watch",
    "codegen:all": "pnpm codegen && pnpm codegen:graphql",
    "docker:health-check": "node scripts/docker-health-check.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/typescript": "^5.0.8",
    "@graphql-codegen/typescript-operations": "^5.0.8",
    "@graphql-codegen/typescript-react-query": "^6.1.1",
    "@ls-lint/ls-lint": "^2.3.1",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "@tanstack/eslint-plugin-query": "^5.91.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "concurrently": "^9.2.1",
    "cspell": "^9.6.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "eslint-plugin-better-tailwindcss": "^4.2.0",
    "eslint-plugin-boundaries": "^5.3.1",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.6",
    "eslint-plugin-testing-library": "^7.15.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^5.82.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "orval": "^7.9.0",
    "prettier": "^3.8.0",
    "secretlint": "^11.3.1",
    "sherif": "^1.10.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "syncpack": "^13.0.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --check",
      "eslint --no-warn-ignored --max-warnings=0",
      "secretlint"
    ],
    "*.{json,md,css}": [
      "prettier --check"
    ]
  },
  "pnpm": {
    "linkWorkspacePackages": true,
    "preferWorkspacePackages": true,
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19"
  }
}
