{
  "name": "candyshop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:store": "turbo dev --filter=store",
    "dev:landing": "turbo dev --filter=landing",
    "dev:payments": "turbo dev --filter=payments",
    "dev:admin": "turbo dev --filter=admin",
    "dev:auth": "turbo dev --filter=auth-app",
    "dev:playground": "turbo dev --filter=playground",
    "dev:studio": "turbo dev --filter=studio",
    "site:up": "node scripts/site-up.mjs",
    "site:up:cloudflare": "node scripts/site-up.mjs --cloudflare",
    "site:prod": "node scripts/site-prod.mjs",
    "site:prod:cloudflare": "node scripts/site-prod.mjs --cloudflare",
    "site:prod:stop": "node scripts/site-prod.mjs --stop",
    "site:prod:public": "powershell -ExecutionPolicy Bypass -File .\\scripts\\site-prod-public.ps1",
    "site:prod:public:stop": "powershell -ExecutionPolicy Bypass -File .\\scripts\\site-prod-public.ps1 -Stop",
    "setup:cloudflare": "node scripts/setup-cloudflare.mjs",
    "build": "turbo build",
    "build:store": "turbo build --filter=store",
    "build:landing": "turbo build --filter=landing",
    "build:payments": "turbo build --filter=payments",
    "build:admin": "turbo build --filter=admin",
    "build:auth": "turbo build --filter=auth-app",
    "build:playground": "turbo build --filter=playground",
    "build:studio": "turbo build --filter=studio",
    "lint": "eslint apps/store/src apps/studio/src apps/landing/src apps/payments/src apps/admin/src apps/auth/src apps/playground/src packages/ui/src packages/shared/src packages/api/src packages/app-components/src packages/auth/src",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:store": "pnpm --filter store test",
    "test:landing": "pnpm --filter landing test",
    "test:payments": "pnpm --filter payments test",
    "test:admin": "pnpm --filter admin test",
    "test:auth": "pnpm --filter auth-app test",
    "test:studio": "pnpm --filter studio test",
    "test:playground": "pnpm --filter playground test",
    "test:watch": "pnpm --filter store test:watch",
    "test:coverage": "turbo test:coverage",
    "test:coverage:store": "pnpm --filter store test:coverage",
    "test:coverage:landing": "pnpm --filter landing test:coverage",
    "test:coverage:payments": "pnpm --filter payments test:coverage",
    "test:coverage:admin": "pnpm --filter admin test:coverage",
    "test:coverage:auth": "pnpm --filter auth-app test:coverage",
    "test:coverage:studio": "pnpm --filter studio test:coverage",
    "test:coverage:playground": "pnpm --filter playground test:coverage",
    "test:shared": "pnpm --filter shared test",
    "test:ui": "pnpm --filter ui test",
    "test:e2e": "turbo test:e2e --concurrency=1",
    "test:e2e:store": "pnpm --filter store test:e2e",
    "test:e2e:landing": "pnpm --filter landing test:e2e",
    "test:e2e:payments": "pnpm --filter payments test:e2e",
    "test:e2e:admin": "pnpm --filter admin test:e2e",
    "test:e2e:auth": "pnpm --filter auth-app test:e2e",
    "smoke": "pnpm --filter auth-app exec playwright test e2e/smoke-all-apps.spec.ts --reporter=line",
    "test:e2e:headed": "turbo test:e2e:headed --concurrency=1",
    "test:e2e:ui": "turbo test:e2e:ui --concurrency=1",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "fix:staged": "lint-staged --concurrent false",
    "fix:all": "pnpm format && eslint --fix apps/store/src apps/studio/src apps/landing/src apps/payments/src apps/admin/src apps/auth/src apps/playground/src packages/ui/src packages/shared/src packages/api/src packages/app-components/src packages/auth/src",
    "stylelint": "stylelint \"apps/*/src/**/*.css\" \"packages/*/src/**/*.css\"",
    "css-sync": "node scripts/check-css-sync.mjs",
    "cspell": "cspell \"apps/*/src/**/*.{ts,tsx,js,jsx,md}\" \"packages/*/src/**/*.{ts,tsx}\"",
    "knip": "knip",
    "jscpd": "jscpd apps/store/src apps/studio/src apps/landing/src apps/payments/src apps/admin/src apps/auth/src apps/playground/src packages/ui/src packages/shared/src packages/api/src packages/app-components/src packages/auth/src",
    "ls-lint": "ls-lint",
    "madge": "madge --circular --extensions ts,tsx,js,jsx apps/store/src apps/studio/src apps/landing/src apps/payments/src apps/admin/src apps/auth/src apps/playground/src packages/ui/src packages/shared/src packages/api/src packages/app-components/src packages/auth/src",
    "check:registry": "bash scripts/check-app-registry.sh",
    "sherif": "sherif",
    "sherif:fix": "sherif --fix",
    "syncpack:lint": "syncpack lint",
    "syncpack:fix": "syncpack fix",
    "secretlint": "secretlint \"**/*\"",
    "semgrep": "semgrep scan --config p/ci --config p/security-audit --config p/owasp-top-ten",
    "precommit": "pnpm lint-staged && pnpm lint && pnpm stylelint && pnpm css-sync && pnpm cspell && pnpm knip && pnpm jscpd && pnpm ls-lint && pnpm madge && pnpm sherif && pnpm syncpack:lint",
    "prepush": "pnpm typecheck && pnpm test:coverage && pnpm build && pnpm test:e2e",
    "codegen": "node scripts/refresh-openapi-mocks.mjs",
    "codegen:fetch": "node scripts/refresh-openapi-mocks.mjs --fetch-only",
    "codegen:process": "node scripts/refresh-openapi-mocks.mjs --process-only",
    "codegen:graphql": "graphql-codegen --config graphql-codegen.ts",
    "codegen:graphql:watch": "graphql-codegen --config graphql-codegen.ts --watch",
    "codegen:supabase": "supabase gen types typescript --local > packages/api/src/supabase/types.ts && node -e \"const f=require('fs');const c=f.readFileSync('packages/api/src/supabase/types.ts','utf8');f.writeFileSync('packages/api/src/supabase/types.ts',c.replace(/^Connecting to db \\d+\\n/,''))\"",
    "codegen:all": "pnpm codegen && pnpm codegen:graphql && pnpm codegen:supabase",
    "user:grant-role": "node scripts/grant-user-role.mjs",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "docker:health-check": "node scripts/docker-health-check.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/typescript": "^5.0.8",
    "@graphql-codegen/typescript-operations": "^5.0.8",
    "@graphql-codegen/typescript-react-query": "^7.0.0",
    "@ls-lint/ls-lint": "^2.3.1",
    "@playwright/test": "^1.58.2",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/eslint-plugin-query": "^5.91.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/eslint-plugin": "^1.6.12",
    "concurrently": "^9.2.1",
    "cspell": "^9.6.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "eslint-plugin-better-tailwindcss": "^4.2.0",
    "eslint-plugin-boundaries": "^6.0.0",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-testing-library": "^7.15.4",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^5.82.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "orval": "^7.9.0",
    "prettier": "^3.8.0",
    "secretlint": "^11.3.1",
    "sherif": "^1.10.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "supabase": "^2.81.3",
    "syncpack": "^14.2.0",
    "tailwindcss": "^4.1.18",
    "turbo": "^2.8.19",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --check",
      "eslint --no-warn-ignored --max-warnings=0",
      "secretlint"
    ],
    "*.{json,md,css}": [
      "prettier --check"
    ]
  },
  "pnpm": {
    "linkWorkspacePackages": true,
    "preferWorkspacePackages": true,
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "msw",
      "sharp",
      "supabase",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "msw": {
    "workerDirectory": [
      "apps\\store\\public",
      "apps\\payments\\public",
      "apps\\admin\\public"
    ]
  }
}
