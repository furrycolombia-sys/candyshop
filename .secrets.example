# Copy this file to .secrets for local `act` runs:
#   cp .secrets.example .secrets
#
# Format:
#   SECRET_NAME=secret-value

AZURE_REGISTRY_USERNAME=replace_me
AZURE_REGISTRY_PASSWORD=replace_me
AZURE_CREDENTIALS={"clientId":"replace_me","clientSecret":"replace_me","subscriptionId":"replace_me","tenantId":"replace_me"}
