# =============================================================================
# E2E environment — isolated Supabase instance on port 64321
# =============================================================================
# Used by: pnpm test:e2e
# Loaded when: TARGET_ENV=e2e
#
# This file is self-contained. An isolated Supabase instance runs on port 64321
# (project: candystore-e2e) with a separate DB volume. The Next.js app runs in
# Docker on port 8089.
# =============================================================================

# ─── Container identity ──────────────────────────────────────────
SITE_PROD_CONTAINER_NAME=candyshop-e2e
SITE_PROD_IMAGE_NAME=candyshop-e2e
SITE_PROD_PORT=8089

# ─── Public origin (what the browser sees) ────────────────────────
SITE_PUBLIC_ORIGIN=http://localhost:8089

# ─── App URLs (baked into Next.js at build time) ──────────────────
NEXT_PUBLIC_LANDING_URL=http://localhost:8089
NEXT_PUBLIC_STORE_URL=http://localhost:8089/store
NEXT_PUBLIC_PAYMENTS_URL=http://localhost:8089/payments
NEXT_PUBLIC_ADMIN_URL=http://localhost:8089/admin
NEXT_PUBLIC_PLAYGROUND_URL=http://localhost:8089/playground
NEXT_PUBLIC_STUDIO_URL=http://localhost:8089/studio
NEXT_PUBLIC_AUTH_URL=http://localhost:8089/auth
NEXT_PUBLIC_AUTH_HOST_URL=http://localhost:8089/auth

# ─── Supabase (isolated e2e instance on port 64321) ───────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:64321
NEXT_PUBLIC_SUPABASE_ANON_KEY=$secret:E2E_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=$secret:E2E_SUPABASE_SERVICE_ROLE_KEY
# Server-side: container reaches e2e Supabase via Docker networking
SUPABASE_URL_INTERNAL=http://host.docker.internal:64321

# ─── Auth provider ────────────────────────────────────────────────
AUTH_PROVIDER_MODE=supabase

# ─── Build flags ──────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_TEST_IDS=true
NEXT_PUBLIC_BUILD_HASH=e2e

# ─── Supabase Auth overrides (read by Supabase CLI at start) ─────
SUPABASE_AUTH_EXTERNAL_REDIRECT_URI=http://localhost:54321/auth/v1/callback
SUPABASE_AUTH_SITE_URL=http://localhost:8089/auth/callback
SUPABASE_AUTH_REDIRECT_URL_AUTH=http://localhost:8089/auth/callback
SUPABASE_AUTH_REDIRECT_URL_STORE=http://localhost:8089/store/auth/callback
SUPABASE_AUTH_REDIRECT_URL_ADMIN=http://localhost:8089/admin/auth/callback
SUPABASE_AUTH_REDIRECT_URL_PAYMENTS=http://localhost:8089/payments/auth/callback
SUPABASE_AUTH_REDIRECT_URL_PLAYGROUND=http://localhost:8089/playground/auth/callback
SUPABASE_AUTH_REDIRECT_URL_LANDING=http://localhost:8089/auth/callback
SUPABASE_AUTH_REDIRECT_URL_STUDIO=http://localhost:8089/studio/auth/callback
