# Recovery-only environment template
# Use this file when a machine is rebuilt and you need to restore public access fast.
# Copy relevant values into `.env` or feed them to `pnpm setup:cloudflare`.

# Public app URLs
NEXT_PUBLIC_LANDING_URL=https://landing.ffxivbe.org
NEXT_PUBLIC_STORE_URL=https://store.ffxivbe.org
NEXT_PUBLIC_AUTH_URL=https://auth.ffxivbe.org
NEXT_PUBLIC_AUTH_HOST_URL=https://auth.ffxivbe.org
NEXT_PUBLIC_PAYMENTS_URL=https://payments.ffxivbe.org
NEXT_PUBLIC_ADMIN_URL=https://admin.ffxivbe.org
NEXT_PUBLIC_STUDIO_URL=https://studio.ffxivbe.org
NEXT_PUBLIC_PLAYGROUND_URL=https://playground.ffxivbe.org

# Cloudflare tunnel
CLOUDFLARED_BIN=cloudflared.exe
CLOUDFLARE_TUNNEL_NAME=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARED_ARGS=
