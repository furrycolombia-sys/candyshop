    "auth": "workspace:*",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "cookies-next": "^6.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "nuqs": "^2.8.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
